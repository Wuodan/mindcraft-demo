# Recommended until this issue fixed: https://github.com/mindcraft-bots/mindcraft/issues/728
# For arm64 (Apple Silicon Mac and Raspberry Pi) also await the PR for python-is-python3
MINDCRAFT_REPO=https://github.com/Wuodan/mindcraft.git
MINDCRAFT_REF=upstream/combined-PR

# Normal mindcraft source
# MINDCRAFT_REPO=https://github.com/mindcraft-bots/mindcraft.git
# MINDCRAFT_REF=develop

# Optional changes

# Optional extra init message
# INIT_MESSAGE="Respond with hello world and your name"
# MC_SERVER_PORT=55916
# DYNMAP_HOST_PORT=8123
# MINDCRAFT_UI_PORT=18080
# Optional on Linux/macOS if your uid/gid is not 1000:1000
# BOT_UID=1000
# BOT_GID=1000

# Example API key in .env (all supported keys can be added the same way):
# OPENROUTER_API_KEY=sk-...
